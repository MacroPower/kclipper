    "topologySpreadConstraints": {
      "type": "array",
      "description": "https://kubernetes.io/docs/concepts/workloads/pods/pod-topology-spread-constraints/",
      "default": []
    },
    "podDisruptionBudget": {
      "type": "object",
      "description": "Disruption budget will be configured only when the replicaCount is greater than 1",
      "additionalProperties": true
    },
    "probes": {
      "type": "object",
      "properties": {
        "readiness": {
          "type": "object",
          "properties": {
            "initialDelaySeconds": {
              "type": "integer",
              "default": 1
            },
            "timeoutSeconds": {
              "type": "integer",
              "default": 5
            },
            "failureThreshold": {
              "type": "integer",
              "default": 3
            },
            "successThreshold": {
              "type": "integer",
              "default": 1
            },
            "periodSeconds": {
              "type": "integer",
              "default": 10
            }
          },
          "additionalProperties": true
        },
        "liveness": {
          "type": "object",
          "properties": {
            "initialDelaySeconds": {
              "type": "integer",
              "default": 1
            },
            "timeoutSeconds": {
              "type": "integer",
              "default": 5
            },
            "failureThreshold": {
              "type": "integer",
              "default": 3
            },
            "successThreshold": {
              "type": "integer",
              "default": 1
            },
            "periodSeconds": {
              "type": "integer",
              "default": 10
            }
          },
          "additionalProperties": true
        },
        "startup": {
          "type": "object",
          "properties": {
            "enable": {
              "type": "boolean",
              "default": false
            },
            "initialDelaySeconds": {
              "type": "integer",
              "default": 10
            },
            "timeoutSeconds": {
              "type": "integer",
              "default": 5
            },
            "failureThreshold": {
              "type": "integer",
              "default": 20
            },
            "successThreshold": {
              "type": "integer",
              "default": 1
            },
            "periodSeconds": {
              "type": "integer",
              "default": 10
            }
          },
          "additionalProperties": true
        }
      },
      "description": "https://kubernetes.io/docs/concepts/workloads/pods/pod-lifecycle#container-probes",
      "additionalProperties": true
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": true
}
