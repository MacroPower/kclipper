{
  "name": "kclipper-dev",
  "engineVersion": "v0.21.4",
  "sdk": {
    "source": "go"
  },
  "toolchains": [
    {
      "name": "go",
      "source": "github.com/MacroPower/x/toolchains/go@main",
      "customizations": [
        {
          "argument": "source",
          "ignore": [
            "**",
            "!**/*.go",
            "!**/go.mod",
            "!**/go.sum",
            "!**/dagger.json",
            "!**/testdata/**",
            "!.golangci.yaml",
            "!modules/**",
            "!resources/**"
          ]
        },
        {
          "argument": "cgo",
          "default": "true"
        },
        {
          "argument": "version",
          "default": "1.25"
        },
        {
          "argument": "cacheNamespace",
          "default": "github.com/macropower/kclipper/toolchains/go"
        }
      ]
    },
    {
      "name": "kclipper",
      "source": "toolchains/kclipper",
      "customizations": [
        {
          "argument": "source",
          "ignore": [
            "**",
            "!**/*.go",
            "!**/go.mod",
            "!**/go.sum",
            "!**/testdata/**",
            "!**/*.yaml",
            "!**/*.json",
            "!**/*.md",
            "!.prettierignore",
            "!.github/**",
            "!hack/**",
            "!.nixpkgs/**",
            "!modules/**",
            "!resources/**",
            "!LICENSE"
          ]
        }
      ]
    },
    {
      "name": "commitlint",
      "source": "toolchains/commitlint"
    },
    {
      "name": "security",
      "source": "github.com/MacroPower/x/toolchains/security@main",
      "customizations": [
        {
          "function": [
            "scanSource"
          ],
          "argument": "source",
          "ignore": [
            "**",
            "!**/*.go",
            "!**/go.mod",
            "!**/go.sum",
            "!.trivyignore"
          ]
        }
      ]
    }
  ],
  "include": [
    "go.mod",
    "go.sum"
  ],
  "source": ".dagger"
}
